# Configuração do ado-cli — copie para .env (nesta mesma pasta da skill) e preencha.
# A CLI lê este .env de .claude/skills/azure-devops-tasks/.env (fallback: ambiente do SO).
# Obrigatórios:
AZDO_PAT=seu-personal-access-token
AZDO_PROJECT=organizacao/projeto

# Opcionais (defaults entre colchetes):
# AZDO_TEAM=Meu Time              # [ {projeto} Team ]
# AZDO_BASE_URL=https://dev.azure.com   # [ https://dev.azure.com ] (on-prem: host da coleção)
# AZDO_API_VERSION=7.1            # [ 7.1 ]
